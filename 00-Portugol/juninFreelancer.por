programa {
  funcao inicio() {
    real denisCobra = 500
    real juninCobra = 500
    real pagaProConsultor = 350 
    real quantidadeHoras
    real juninDeveCobrar
    escreva("quantidade horas: ")
    leia(quantidadeHoras)
    juninDeveCobrar = quantidadeHoras * pagaProConsultor
    escreva("quanto deve cobrar: " + juninDeveCobrar)
    real lucro 
    lucro = juninDeveCobrar - denisCobra
    escreva("\no lucro do freela foi: " + lucro)






  }
}
