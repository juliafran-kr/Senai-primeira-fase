programa {
  funcao inicio() {
    inteiro caminhoes
    real lucroPorCaminhao, lucroTotal
    lucroPorCaminhao = (90*50) - 450
    //escreva(lucroPorCaminhao)
    escreva ("quantos caminhoes: ") 
    leia (caminhoes)
    lucroTotal = lucroPorCaminhao * caminhoes
    escreva ("lucro da temporada: " + lucroTotal)

  }
}
